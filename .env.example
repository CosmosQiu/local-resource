# =============================================================================
# AI Resource Hub — Environment Variables
# Copy to .env and fill in your values before running docker compose up
# =============================================================================

# -------------------- Database (PostgreSQL 15) --------------------
POSTGRES_USER=arh_admin
POSTGRES_PASSWORD=arh_secret
POSTGRES_DB=ai_resource_hub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async database URL (SQLAlchemy + psycopg 3 async)
DATABASE_URL=postgresql+psycopg_async://arh_admin:arh_secret@localhost:5432/ai_resource_hub

# -------------------- Redis --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery broker
CELERY_BROKER_URL=redis://localhost:6379/1

# -------------------- JWT Authentication --------------------
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# -------------------- Vault Encryption (API Keys at rest) --------------------
# 32-byte hex string for AES-256-GCM
VAULT_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# -------------------- Monitoring (Prometheus + Grafana) --------------------
# Prometheus scrapes node_exporter on managed hosts.
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# -------------------- Pi Agent (container provisioning) --------------------
# Path to the pi CLI.  Install: npm install -g @earendil-works/pi-coding-agent
PI_COMMAND=pi
PI_TIMEOUT=300
# DeepSeek API — OpenAI-compatible format for Pi's LLM backend
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# -------------------- Ansible (fallback for non-GPUStack hosts) --------------------
ANSIBLE_INVENTORY_PATH=./ansible/inventory
ANSIBLE_PLAYBOOK_PATH=./ansible/playbooks

# -------------------- App --------------------
APP_NAME=AI Resource Hub
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
